# Copy this file to .env and fill in the values.

# ── Container engine ───────────────────────────────────────────────────────────
# Default engine used by justfile compose recipes (up/down/logs).
# Set to `docker` if you prefer Docker Compose.
CONTAINER_ENGINE=podman

# ── Cloudflare Tunnel (optional) ──────────────────────────────────────────────
# Required only if you uncomment the `cloudflared` service in compose.yaml.
# Get the token from: https://one.dash.cloudflare.com → Networks → Tunnels
CLOUDFLARE_TUNNEL_TOKEN=
